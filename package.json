{
  "name": "react-compoviewer",
  "version": "0.1.0",
  "description": "Instantly preview any React component from your codebase in a side panel — no Storybook setup required",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.mjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs"
    }
  },
  "bin": {
    "compoviewer": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "react-docgen-typescript": "^2.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "react",
    "component",
    "viewer",
    "preview",
    "devtool",
    "storybook-alternative",
    "vite-plugin"
  ],
  "license": "MIT"
}
